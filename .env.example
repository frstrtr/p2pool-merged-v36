# ── P2Pool Docker Environment ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All passwords and addresses below are REQUIRED.
#
# docker compose up -d

# ── Litecoin Core ────────────────────────────────────────────────────────
# Where is your Litecoin Core daemon?
# Use "host.docker.internal" if it runs on the Docker host machine.
# Use a LAN IP if it runs on another machine.
LTC_DAEMON_HOST=host.docker.internal
LTC_RPC_PORT=9332
LTC_P2P_PORT=9333
LTC_RPC_USER=litecoinrpc
LTC_RPC_PASSWORD=CHANGE_ME

# ── Dogecoin Core ────────────────────────────────────────────────────────
# Where is your Dogecoin Core daemon?
DOGE_DAEMON_HOST=host.docker.internal
DOGE_P2P_PORT=22556
DOGE_RPC_USER=dogecoinrpc
DOGE_RPC_PASSWORD=CHANGE_ME

# ── Payout Address ────────────────────────────────────────────────────────
# Your Litecoin payout address (MUST be legacy format starting with L)
# Generate with: litecoin-cli getnewaddress "" legacy
LTC_PAYOUT_ADDRESS=

# ── Pool Settings ─────────────────────────────────────────────────────────
# Donation to P2Pool development (percentage, default 2%)
DONATE_PERCENT=2
# Node operator fee (percentage, default 0%)
NODE_FEE=0
# Share redistribution mode: pplns | fee | boost | donate
REDISTRIBUTE=boost
# Maximum peer connections
MAX_CONNS=20

# ── Network ───────────────────────────────────────────────────────────────
# Exposed ports on the Docker host
P2POOL_STRATUM_PORT=9327
P2POOL_P2P_PORT=9326

# Timezone (for log timestamps)
TZ=UTC
